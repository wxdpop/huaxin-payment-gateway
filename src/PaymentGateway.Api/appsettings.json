{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MySql": "Server=localhost;Database=payment_gateway;User ID=root;Password=123456;Charset=utf8mb4;Port=3306;SslMode=None;AllowPublicKeyRetrieval=True"
  },
  "Redis": {
    "Endpoints": [
      "localhost:7000",
      "localhost:7001",
      "localhost:7002",
      "localhost:7003",
      "localhost:7004",
      "localhost:7005"
    ],
    "Password": "",
    "NullMarker": "<<NULL>>",
    "NullCacheExpirySeconds": 60,
    "JitterRatio": 0.2
  },
  "DistributedLock": {
    "RedisEndpoints": [
      "localhost:7000",
      "localhost:7001",
      "localhost:7002",
      "localhost:7003",
      "localhost:7004",
      "localhost:7005"
    ],
    "ZooKeeperEndpoint": "localhost:2181",
    "ZooKeeperLockRoot": "/locks/payment-gateway",
    "ZkSessionTimeoutMs": 30000,
    "DefaultExpiryMs": 5000,
    "WatchdogRenewRatio": 3.0,
    "AcquireTimeoutMs": 200,
    "RetryCount": 3,
    "RetryBaseDelayMs": 100,
    "DefaultType": "Dual"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092"
  },
  "EventBus": {
    "BootstrapServers": "localhost:29092",
    "DefaultConsumerGroup": "payment-gateway",
    "ProducerAcks": "all",
    "MessageTimeoutMs": 10000,
    "SessionTimeoutMs": 30000,
    "AutoCommitIntervalMs": 0,
    "MaxRetryCount": 3,
    "UseInMemory": true
  },
  "Jaeger": {
    "OtlpEndpoint": "http://localhost:4317",
    "ServiceName": "PaymentGateway",
    "Enabled": true
  },
  "ZeroMq": {
    "ReqRepEndpoint": "inproc://risk-check",
    "PubSubEndpoint": "tcp://*:5556",
    "RequestTimeoutMs": 3000,
    "Enabled": true
  },
  "Idempotent": {
    "HeaderName": "Idempotency-Key",
    "KeyPrefix": "idempotent:",
    "Expiry": "24:00:00",
    "ProcessingTimeout": "00:00:30"
  },
  "AllowedHosts": "*"
}

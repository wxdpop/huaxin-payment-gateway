{
  // ============================================================================
  // 容器化环境覆盖配置 (ASPNETCORE_ENVIRONMENT=Docker 时加载)
  // ============================================================================
  // ★ 学习要点: ASP.NET Core 配置加载顺序
  //   1. appsettings.json (基础配置)
  //   2. appsettings.{Environment}.json (本文件,覆盖同名键)
  //   3. 环境变量 (覆盖同名键,优先级最高)
  //   4. 命令行参数 (最高优先级)
  //
  // 【为什么需要容器化专属配置?】
  //   - appsettings.json 用 localhost 连接中间件,适合"应用在本机跑、中间件在 Docker"
  //   - 容器化后应用本身也在 payment-net 网络内,需用"服务名"互访(redis-1/zookeeper/kafka)
  //   - MySQL 仍在宿主机运行,容器内通过 host.docker.internal 访问宿主机端口
  //
  // 【host.docker.internal 说明】
  //   - Docker Desktop for Windows/Mac 提供的特殊 DNS,解析为宿主机 IP
  //   - Linux 原生 Docker 需添加 --add-host=host.docker.internal:host-gateway
  //   - 本工程假定 Docker Desktop 环境,直接使用
  // ============================================================================
  "ConnectionStrings": {
    // MySQL 在宿主机运行,容器内通过 host.docker.internal:3306 访问
    "MySql": "Server=host.docker.internal;Database=payment_gateway;User ID=root;Password=123456;Charset=utf8mb4;Port=3306;SslMode=None;AllowPublicKeyRetrieval=True"
  },
  "Redis": {
    // 缓存 Redis 用容器间服务名 (payment-net 网络内 DNS 解析)
    "Endpoints": [
      "redis-1:7000",
      "redis-2:7001",
      "redis-3:7002",
      "redis-4:7003",
      "redis-5:7004",
      "redis-6:7005"
    ]
  },
  "DistributedLock": {
    // Redlock 投票节点用容器间服务名 (6 个独立实例,符合 Redlock 论文)
    "RedisEndpoints": [
      "redis-1:7000",
      "redis-2:7001",
      "redis-3:7002",
      "redis-4:7003",
      "redis-5:7004",
      "redis-6:7005"
    ],
    // ZK 用容器间服务名
    "ZooKeeperEndpoint": "zookeeper:2181"
  },
  "Kafka": {
    // 容器间走 INTERNAL 监听器 (kafka:9092),宿主机走 EXTERNAL (localhost:29092)
    "BootstrapServers": "kafka:9092"
  },
  "EventBus": {
    "BootstrapServers": "kafka:9092",
    // ★ 容器化联调: 切换为 Kafka 模式 (真实事件驱动,验证消费者链路)
    //   本地开发 (appsettings.json) 用 true (内存模式,免依赖 Kafka)
    "UseInMemory": false
  },
  "Jaeger": {
    // OTLP gRPC 上报地址用容器间服务名
    "OtlpEndpoint": "http://jaeger:4317"
  }
}
